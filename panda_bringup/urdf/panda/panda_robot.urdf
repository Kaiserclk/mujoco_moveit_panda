<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="panda">

  <xacro:arg name="headless" default="false"/>

  <link name="world"/>
  <link name="link0"/>
  <joint name="base_joint" type="fixed">
    <parent link="world"/>
    <child link="link0"/>
  </joint>

  <link name="link1"/>
  <joint name="joint1" type="revolute">
    <parent link="link0"/>
    <child link="link1"/>
    <origin xyz="0 0 0.333"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" velocity="2.175" effort="87"/>
  </joint>

  <link name="link2"/>
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.7628" upper="1.7628" velocity="2.175" effort="87"/>
  </joint>

  <link name="link3"/>
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 -0.316 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" velocity="2.175" effort="87"/>
  </joint>

  <link name="link4"/>
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.0825 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0718" upper="-0.0698" velocity="2.175" effort="87"/>
  </joint>

  <link name="link5"/>
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="-0.0825 0.384 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" velocity="2.61" effort="12"/>
  </joint>

  <link name="link6"/>
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.0175" upper="3.7525" velocity="2.61" effort="12"/>
  </joint>

  <link name="link7"/>
  <joint name="joint7" type="revolute">
    <parent link="link6"/>
    <child link="link7"/>
    <origin xyz="0.088 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" velocity="2.61" effort="12"/>
  </joint>

  <link name="hand"/>
  <joint name="hand_joint" type="fixed">
    <parent link="link7"/>
    <child link="hand"/>
    <origin xyz="0 0 0.107" rpy="0 0 -0.7853981633974483"/>
  </joint>

  <link name="left_finger"/>
  <joint name="finger_joint1" type="prismatic">
    <parent link="hand"/>
    <child link="left_finger"/>
    <origin xyz="0 0 0.0584"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.04" velocity="0.2" effort="20"/>
  </joint>

  <link name="right_finger"/>
  <joint name="finger_joint2" type="prismatic">
    <parent link="hand"/>
    <child link="right_finger"/>
    <origin xyz="0 0 0.0584"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.04" velocity="0.2" effort="20"/>
  </joint>

  <ros2_control name="MujocoSystem" type="system">
    <hardware>
      <plugin>mujoco_ros2_control/MujocoSystemInterface</plugin>
      <param name="mujoco_model">$(find panda_bringup)/urdf/panda/panda_scene.xml</param>
      <param name="sim_speed_factor">1.0</param>
      <param name="headless">$(arg headless)</param>
    </hardware>

    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-0.0698</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint5">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint6">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint7">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="finger_joint1">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.04</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="finger_joint2">
      <state_interface name="position"><param name="initial_value">0.04</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
</robot>
